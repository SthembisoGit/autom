NODE_ENV=development
APP_URL=http://localhost:4010
OPS_URL=http://localhost:4173
APP_PORT=4010
SESSION_SECRET=replace-with-a-long-random-secret
DATABASE_URL=var/db/autom.sqlite
MEDIA_ROOT=var
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
FFMPEG_COMMAND_TIMEOUT_SECONDS=600
GEMINI_API_KEY=
GEMINI_SCRIPT_MODEL=gemini-2.5-flash
GROQ_API_KEY=
GROQ_SCRIPT_MODEL=llama-3.3-70b-versatile
GROQ_SCRIPT_TIMEOUT_SECONDS=45
GROQ_TRANSCRIPTION_MODEL=whisper-large-v3-turbo
GROQ_TRANSCRIPTION_TIMEOUT_SECONDS=120
TAVILY_API_KEY=
COHERE_API_KEY=
MISTRAL_API_KEY=
MISTRAL_SCRIPT_MODEL=mistral-small-latest
MISTRAL_SCRIPT_TIMEOUT_SECONDS=45
DEEPGRAM_API_KEY=
# Google TTS — recommended voice provider. Free: 1M Neural2 chars/month.
# Get key: console.cloud.google.com → APIs & Services → Cloud Text-to-Speech API
# Recommended voices: en-US-Neural2-J (male), en-US-Neural2-F (female)
# South African English: en-ZA-Standard-A
GOOGLE_TTS_API_KEY=
PEXELS_API_KEY=
PIXABAY_API_KEY=
VISUAL_PROVIDER_TIMEOUT_SECONDS=45
SCHEDULER_ENABLED=true
SCHEDULER_POLL_INTERVAL_SECONDS=30
SCHEDULER_MAX_RETRIES=3
SCHEDULER_RETRY_BASE_SECONDS=300
ENABLED_PUBLISHER_PLATFORMS=local,youtube
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:4010/publications/connections/youtube/callback
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:4010/publications/connections/tiktok/callback
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:4010/publications/connections/facebook/callback
META_PAGE_ID=
